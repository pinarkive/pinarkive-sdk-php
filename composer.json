{
    "name": "pinarkive/pinarkive-sdk-php",
    "version": "3.1.2",
    "description": "PHP SDK for PinArkive API v3 – minimal client (upload, pin, remove, users/me, uploads, tokens, status, allocations). See https://docs.pinarkive.com",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "ITCS VIP",
            "email": "support@pinarkive.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Pinarkive\\": "./"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pinarkive\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "pinarkive",
        "api",
        "sdk",
        "php",
        "v3",
        "directory-dag",
        "pinning",
        "api-keys",
        "ipfs",
        "file-management",
        "laravel",
        "symfony"
    ],
    "homepage": "https://pinarkive.com",
    "support": {
        "issues": "https://github.com/pinarkive/pinarkive-sdk-php/issues",
        "source": "https://github.com/pinarkive/pinarkive-sdk-php",
        "docs": "https://docs.pinarkive.com"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
